# Per-developer overrides for the Telegram client.
# Shared secrets live in the root .env (managed by setup.sh). Duplicating keys
# here will silently override the root value — only put per-developer knobs here.

# LOG_LEVEL=debug
# TELEGRAM_PORT=3003

# Multi-burst response delivery (Telegram per-chat limit ~1 msg/sec).
# MESSAGE_SPLIT_ENABLED=true
# MESSAGE_SPLIT_BASE_DELAY_MS=1000
# MESSAGE_SPLIT_PER_CHAR_MS=25
# MESSAGE_SPLIT_MAX_DELAY_MS=3500
# MESSAGE_SPLIT_MAX_CHUNKS=5
