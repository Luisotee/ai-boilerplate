# WhatsApp Cloud Client - Local Overrides
# Copy to .env.local for development customizations.
# These override values from the root .env file.
#
# IMPORTANT: shared secrets (META_*, GEMINI_API_KEY, POSTGRES_PASSWORD, AI_API_KEY, ...)
# live in root .env only. Do NOT duplicate them here — .env.local loads with
# override:true, so a stale value here will silently shadow root .env.

# Uncomment to customize
# LOG_LEVEL=debug
# WHATSAPP_CLOUD_PORT=3002
# WHATSAPP_CLOUD_HOST=0.0.0.0
