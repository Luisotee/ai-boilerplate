# === Infrastructure (Docker Compose) ===
POSTGRES_USER=aiagent
# REQUIRED: Set a strong password
POSTGRES_PASSWORD=
POSTGRES_DB=aiagent

# === Database ===
DATABASE_URL=postgresql://aiagent:YOUR_POSTGRES_PASSWORD@localhost:5432/aiagent

# Database Connection Pooling
# Number of persistent connections
DB_POOL_SIZE=20
# Additional connections when pool exhausted
DB_MAX_OVERFLOW=10
# Seconds to wait for connection
DB_POOL_TIMEOUT=30
# Recycle connections after N seconds (1 hour)
DB_POOL_RECYCLE=3600
# Test connections before use
DB_POOL_PRE_PING=true
# Log pool checkouts (debug only)
DB_ECHO_POOL=false

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REQUIRED: Set a strong password
REDIS_PASSWORD=

# === API Keys (External Services) ===
# REQUIRED: Google Gemini API key
GEMINI_API_KEY=
# Optional: Groq API key for STT (cloud Whisper)
GROQ_API_KEY=

# === Speech-to-Text Provider ===
# Provider selection: auto | groq | whisper
#   auto    - Prefer Groq when GROQ_API_KEY is set; fall back to self-hosted
#             Whisper (WHISPER_BASE_URL) on recoverable errors. Use self-hosted
#             alone when only WHISPER_BASE_URL is set.
#   groq    - Always use Groq (no fallback)
#   whisper - Always use self-hosted Whisper (no fallback)
STT_PROVIDER=auto
# Self-hosted Whisper (optional). Start the container with:
#   docker compose --profile whisper up -d
# In-cluster URL (Docker): http://whisper:8000
# Host-side dev URL:       http://127.0.0.1:8771
# WHISPER_BASE_URL=http://whisper:8000
WHISPER_MODEL=Systran/faster-distil-whisper-large-v3
WHISPER_TIMEOUT_SECONDS=120
# Optional: LlamaCloud API key for PDF parsing via LlamaParse (primary PDF parser).
# Get one at https://cloud.llamaindex.ai (free tier: 1000 pages/day).
# If unset AND the [docling] extra is installed, Docling is used as a local fallback.
LLAMA_CLOUD_API_KEY=

# === Inter-Service Authentication ===
# REQUIRED: Key for authenticating requests to AI API
AI_API_KEY=
# REQUIRED: Key for authenticating requests to WhatsApp API
WHATSAPP_API_KEY=
# Optional: separate key for Cloud API client (defaults to WHATSAPP_API_KEY)
WHATSAPP_CLOUD_API_KEY=
# Optional: separate key for Telegram client (defaults to WHATSAPP_API_KEY)
TELEGRAM_API_KEY=

# === User Whitelist ===
# Comma-separated phone numbers and/or group JIDs (empty = all allowed).
#   - WhatsApp Baileys: accepts phones ("5511999999999") and group JIDs ("120363...@g.us")
#   - WhatsApp Cloud:   accepts phones only (webhook payload has no group context)
#   - Telegram:         use full synthetic JIDs ("tg:123456789" for users, "tg:-1001234567890" for groups)
WHITELIST_PHONES=

# === CORS ===
# Comma-separated allowed origins (e.g., http://localhost:3000)
CORS_ORIGINS=

# === Rate Limiting ===
# Global requests per minute
RATE_LIMIT_GLOBAL=30
# Expensive operation requests per minute
RATE_LIMIT_EXPENSIVE=5

# === Services ===
AI_API_URL=http://localhost:8000
WHATSAPP_API_PORT=3001
WHATSAPP_API_HOST=0.0.0.0
WHATSAPP_CLOUD_CLIENT_URL=http://localhost:3002
WHATSAPP_CLOUD_PORT=3002
WHATSAPP_CLOUD_HOST=0.0.0.0
TELEGRAM_CLIENT_URL=http://localhost:3003
TELEGRAM_PORT=3003
TELEGRAM_HOST=0.0.0.0

# Fetch Timeouts (milliseconds)
# Default timeout for API calls (30s)
FETCH_TIMEOUT_DEFAULT_MS=30000
# Audio transcription timeout (60s)
FETCH_TIMEOUT_TRANSCRIPTION_MS=60000
# Text-to-speech timeout (45s)
FETCH_TIMEOUT_TTS_MS=45000
# Job status polling timeout (5s)
FETCH_TIMEOUT_POLLING_MS=5000

# Job Polling Configuration
# Interval between polling attempts (500ms)
POLL_INTERVAL_MS=500
# Max polling iterations (240 * 500ms = 2 minutes)
POLL_MAX_ITERATIONS=240
# Max total polling duration (2 minutes)
POLL_MAX_DURATION_MS=120000

# === PDF Processing (Python AI API) ===
# Parser selection: auto | llamaparse | docling
#   auto       - Prefer LlamaParse when LLAMA_CLOUD_API_KEY is set; fall back to Docling
#                (if the [docling] extra is installed) on any LlamaParse error.
#   llamaparse - Always use LlamaParse; fail if no key or on any parse error.
#   docling    - Always use Docling (requires `uv sync --extra docling`).
PDF_PARSER=auto
# If true, bakes the Python [docling] extra + OCR system deps (poppler-utils,
# tesseract-ocr, libmagic1) into the Docker image. Read as a build arg by
# docker-compose.yml. Enabled automatically by setup.sh when Docling is chosen.
INSTALL_DOCLING=false
# LlamaParse tier: fast | cost_effective | agentic | agentic_plus
# cost_effective (~0.4¢/page) beats Docling on layout per ParseBench; agentic (~1.2¢/page) is most accurate.
LLAMAPARSE_TIER=cost_effective
# LlamaParse per-parse timeout. Must be strictly < KB_PROCESSING_TIMEOUT_SECONDS
# so the inner parser timeout fires before the outer wrapper.
LLAMAPARSE_TIMEOUT_SECONDS=240

# Timeouts
# Overall max processing time (must be > LLAMAPARSE_TIMEOUT_SECONDS).
KB_PROCESSING_TIMEOUT_SECONDS=360
# Max time for local PDF parsing (Docling path) (3 minutes)
KB_PARSE_TIMEOUT_SECONDS=180
# Max time per embedding API call (10 seconds)
KB_EMBEDDING_TIMEOUT_SECONDS=10
# Max time for all embeddings (4 minutes)
KB_EMBEDDING_BATCH_TIMEOUT_SECONDS=240

# === WhatsApp Cloud API (Meta) ===
# REQUIRED: Meta phone number ID
META_PHONE_NUMBER_ID=
# REQUIRED: Meta access token
META_ACCESS_TOKEN=
# REQUIRED: Meta app secret for webhook HMAC verification
META_APP_SECRET=
# Webhook verification token (set to match Meta dashboard)
META_WEBHOOK_VERIFY_TOKEN=
# Meta Graph API version
META_GRAPH_API_VERSION=v23.0

# === Telegram Bot (grammY) ===
# Start the container with: docker compose --profile telegram up -d
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Secret token sent by Telegram in X-Telegram-Bot-Api-Secret-Token on every
# webhook delivery. setup.sh generates a random 32-char value for you.
# Allowed charset: A-Z a-z 0-9 _ -  (1–256 chars)
TELEGRAM_WEBHOOK_SECRET=
# Public HTTPS URL where Telegram should POST updates (e.g. an ngrok/cloudflared
# tunnel pointing at /webhook). Leave empty to skip setWebhook on startup.
TELEGRAM_PUBLIC_WEBHOOK_URL=
# If true (default), drop updates that were queued while the bot was offline
# on webhook registration. Set to false to replay them instead.
TELEGRAM_DROP_PENDING_UPDATES=true

# === WhatsApp Reconnection Strategy (TypeScript Client) ===
# Initial delay before first reconnection (1 second)
RECONNECT_INITIAL_DELAY_MS=1000
# Maximum delay between reconnection attempts (30 seconds)
RECONNECT_MAX_DELAY_MS=30000
# Maximum reconnection attempts before giving up
RECONNECT_MAX_ATTEMPTS=10
# Random jitter to add to delay (prevents thundering herd)
RECONNECT_JITTER_MS=500

# === Message Splitting (human-like bursts) ===
# When enabled (default), the AI agent can insert a `---` line to split its
# reply into multiple WhatsApp messages with typing delays between them.
# Splitting only applies to private chats; groups always receive a single message.
MESSAGE_SPLIT_ENABLED=true
# Fixed delay before each follow-up chunk (ms)
MESSAGE_SPLIT_BASE_DELAY_MS=600
# Extra delay per character in the upcoming chunk (simulates typing speed)
MESSAGE_SPLIT_PER_CHAR_MS=25
# Upper bound on the computed delay (ms)
MESSAGE_SPLIT_MAX_DELAY_MS=3500
# Hard cap on chunks per response (excess chunks are merged into the last one)
MESSAGE_SPLIT_MAX_CHUNKS=5

# === Logging ===
LOG_LEVEL=info

# === Observability (optional) ===
# Sentry DSN for Node.js error tracking (leave empty to disable)
SENTRY_DSN_NODE=
# Environment label (defaults to NODE_ENV or 'development')
SENTRY_ENVIRONMENT=
# Trace sample rate 0.0–1.0 (default 0 = errors only, no performance tracing)
SENTRY_TRACES_SAMPLE_RATE=0
